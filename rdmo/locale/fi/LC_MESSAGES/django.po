#: accounts/templates/account/email.html:6
msgid "E-mail Addresses"
msgstr "Sähköpostiosoitteet"

#: accounts/templates/account/email.html:10
msgid "The following e-mail addresses are associated with your account:"
msgstr "Seuraavat sähköpostiosoitteet on liitetty käyttäjätiliisi:"

#: accounts/templates/account/email.html:26
msgid "Primary"
msgstr "Ensisijainen"

#: accounts/templates/account/email.html:30
msgid "Verified"
msgstr "Vahvistettu"

#: accounts/templates/account/email.html:32
msgid "Unverified"
msgstr "Vahvistamaton"

#: accounts/templates/account/email.html:40
msgid "Make Primary"
msgstr "Aseta ensisijaiseksi"

#: accounts/templates/account/email.html:41
msgid "Re-send Verification"
msgstr "Lähetä vahvistus uudelleen"

#: accounts/templates/account/email.html:42
msgid "Remove"
msgstr "Poista"

#: accounts/templates/account/email.html:51
msgid "Warning:"
msgstr "Varoitus:"

#: accounts/templates/account/email.html:51
msgid "You currently do not have any e-mail address set up. You should really add an e-mail address so you can receive notifications, reset your password, etc."
msgstr "Käyttäjätilillesi ei ole tällä hetkellä lisätty sähköpostiosoitetta. Lisää sähköpostiosoite, jotta voit vastaanottaa ilmoituksia, palauttaa salasanasi ja käyttää muita tilitoimintoja."

#: accounts/templates/account/email.html:56
msgid "Add E-mail Address"
msgstr "Lisää sähköpostiosoite"

#: accounts/templates/account/email.html:63
msgid "Add E-mail"
msgstr "Lisää sähköposti"

#: accounts/templates/account/email.html:71
msgid "Do you really want to remove the selected e-mail address?"
msgstr "Haluatko varmasti poistaa valitun sähköpostiosoitteen?"

#: accounts/templates/account/email/password_reset_key_message.txt:1 projects/templates/projects/email/project_invite_message.txt:1
msgid "Dear"
msgstr "Hyvä"

#: accounts/templates/account/email/password_reset_key_message.txt:3
#, python-format
msgid "You are receiving this e-mail because you requested that your password on %(site_domain)s will be reset. It can be safely ignored if you did not request a password reset. Click the link below to reset your password."
msgstr "Saat tämän sähköpostin, koska pyysit salasanan palauttamista sivustolla %(site_domain)s. Jos et pyytänyt salasanan palauttamista, voit jättää tämän viestin huomiotta. Palauta salasanasi napsauttamalla alla olevaa linkkiä."

#: accounts/templates/account/email/password_reset_key_message.txt:11
#, python-format
msgid "In case you forgot, your username is '%(username)s'."
msgstr "Käyttäjätunnuksesi on '%(username)s', mikäli olet unohtanut sen."

#: accounts/templates/account/email/password_reset_key_message.txt:15 projects/templates/projects/email/project_contact_message.txt:34 projects/templates/projects/email/project_invite_message.txt:16 projects/templates/projects/issue_send_message.txt:9
msgid "Sincerely"
msgstr "Ystävällisin terveisin"

#: accounts/templates/account/email/password_reset_key_subject.txt:1 accounts/templates/account/password_reset.html:6
msgid "Password reset"
msgstr "Salasanan palauttaminen"

#: accounts/templates/account/email_confirm.html:7
msgid "Confirm E-mail Address"
msgstr "Vahvista sähköpostiosoite"

#: accounts/templates/account/email_confirm.html:14
#, python-format
msgid "Please confirm that <a href=\"mailto:%(email)s\">%(email)s</a> is an e-mail address for user <strong>%(user_display)s</strong>."
msgstr "Vahvista, että <a href=\"mailto:%(email)s\">%(email)s</a> on käyttäjän <strong>%(user_display)s</strong> sähköpostiosoite."

#: accounts/templates/account/email_confirm.html:21
msgid "Confirm"
msgstr "Vahvista"

#: accounts/templates/account/email_confirm.html:29
#, python-format
msgid "This e-mail confirmation link expired or is invalid. Please <a href=\"%(email_url)s\">issue a new e-mail confirmation request</a>."
msgstr "Tämä sähköpostiosoitteen vahvistuslinkki on vanhentunut tai virheellinen. <a href=\"%(email_url)s\">Pyydä uusi vahvistusviesti</a>."

#: accounts/templates/account/login.html:6 accounts/templates/account/login_form.html:23 accounts/templates/account/password_reset_from_key_done.html:14 core/templates/core/base_navigation.html:124 core/templates/core/home.html:57
msgid "Login"
msgstr "Kirjaudu sisään"

#: accounts/templates/account/login_form.html:6
msgid "Login with Shibboleth"
msgstr "Kirjaudu Shibbolethilla"

#: accounts/templates/account/login_form_account.html:7
#, python-format
msgid "If you have not created an account yet, then please <a href=\"%(signup_url)s\">sign up</a> first."
msgstr "Jos et ole vielä luonut käyttäjätiliä, <a href=\"%(signup_url)s\">rekisteröidy</a> ensin."

#: accounts/templates/account/login_form_account.html:14
#, python-format
msgid "If you forgot your password and want to reset it, click <a href=\"%(reset_url)s\">here</a>."
msgstr "Jos olet unohtanut salasanasi ja haluat palauttaa sen, napsauta <a href=\"%(reset_url)s\">tästä</a>."

#: accounts/templates/account/login_form_socialaccount.html:9
msgid "Alternatively, you can login using one of the following third party accounts:"
msgstr "Voit myös kirjautua sisään jollakin seuraavista kolmannen osapuolen käyttäjätileistä:"

#: accounts/templates/account/logout.html:6 accounts/templates/account/logout.html:19 accounts/templates/account/logout_form.html:6 core/templates/core/base_navigation.html:113
msgid "Logout"
msgstr "Kirjaudu ulos"

#: accounts/templates/account/logout.html:9
msgid "Are you sure you want to sign out?"
msgstr "Haluatko varmasti kirjautua ulos?"

#: accounts/templates/account/password_change.html:6 accounts/templates/account/password_change.html:17 core/templates/core/base_navigation_account.html:7
msgid "Change password"
msgstr "Vaihda salasana"

#: accounts/templates/account/password_change.html:9
msgid "Please enter your old password, and then enter your new password twice so we can verify you typed it in correctly."
msgstr "Anna nykyinen salasanasi ja kirjoita uusi salasanasi kahdesti, jotta voimme varmistaa, että kirjoitit sen oikein."

#: accounts/templates/account/password_reset.html:13
msgid "Forgotten your password? Enter your e-mail address below, and we'll send you an e-mail allowing you to reset it."
msgstr "Oletko unohtanut salasanasi? Anna sähköpostiosoitteesi alla, niin lähetämme sinulle sähköpostin, jonka avulla voit palauttaa salasanasi."

#: accounts/templates/account/password_reset.html:21
msgid "Reset my password"
msgstr "Palauta salasanani"

#: accounts/templates/account/password_reset_done.html:6
msgid "Password reset sent"
msgstr "Salasanan palautusviesti on lähetetty"

#: accounts/templates/account/password_reset_done.html:13
msgid "We have sent you an e-mail. Please contact us if you do not receive it within a few minutes."
msgstr "Olemme lähettäneet sinulle sähköpostiviestin. Ota yhteyttä, jos et saa sitä muutaman minuutin kuluessa."

#: accounts/templates/account/password_reset_done.html:19
msgid "If you don't receive an e-mail, please make sure you've entered the address you registered with, and check your spam folder."
msgstr "Jos et saa sähköpostiviestiä, varmista, että annoit rekisteröitymisessä käyttämäsi osoitteen, ja tarkista roskapostikansiosi."

#: accounts/templates/account/password_reset_from_key.html:8
msgid "Bad token"
msgstr "Virheellinen tunniste"

#: accounts/templates/account/password_reset_from_key.html:12
#, python-format
msgid "The password reset link was invalid, possibly because it has already been used. Please request a <a href=\"%(passwd_reset_url)s\">new password reset</a>."
msgstr "Salasanan palautuslinkki oli virheellinen, mahdollisesti siksi, että sitä on jo käytetty. Pyydä <a href=\"%(passwd_reset_url)s\">uusi salasanan palautuslinkki</a>."

#: accounts/templates/account/password_reset_from_key.html:18
msgid "Enter new password"
msgstr "Syötä uusi salasana"

#: accounts/templates/account/password_reset_from_key.html:27
msgid "Change my password"
msgstr "Vaihda salasanani"

#: accounts/templates/account/password_reset_from_key.html:33
msgid "Your password is now changed."
msgstr "Salasanasi on nyt vaihdettu."

#: accounts/templates/account/password_reset_from_key_done.html:7
msgid "Password reset complete"
msgstr "Salasanan palautus valmis"

#: accounts/templates/account/password_reset_from_key_done.html:10
msgid "Your password has been set. You may go ahead and log in now."
msgstr "Salasanasi on asetettu. Voit nyt kirjautua sisään."

#: accounts/templates/account/password_set.html:6
msgid "Set new password"
msgstr "Aseta uusi salasana"

#: accounts/templates/account/password_set.html:9
msgid "Please enter your new password twice so we can verify you typed it in correctly."
msgstr "Syötä uusi salasanasi kahdesti, jotta voimme varmistaa, että kirjoitit sen oikein."

#: accounts/templates/account/password_set.html:17
msgid "Set password"
msgstr "Aseta salasana"

#: accounts/templates/account/signup.html:6 accounts/templates/socialaccount/signup.html:6
msgid "Create a new account"
msgstr "Luo uusi käyttäjätili"

#: accounts/templates/account/signup.html:9
#, python-format
msgid "Already have an account? Then please <a href=\"%(login_url)s\">sign in</a>."
msgstr "Onko sinulla jo käyttäjätili? <a href=\"%(login_url)s\">Kirjaudu sisään</a>."

#: accounts/templates/account/signup.html:34 accounts/templates/socialaccount/signup.html:33
msgid "I agree to the <a href=\"\">terms of use</a>."
msgstr "Hyväksyn <a href=\"\">käyttöehdot</a>."

#: accounts/templates/account/signup.html:41 accounts/templates/socialaccount/signup.html:40
msgid "You need to agree to the terms of use to proceed."
msgstr "Sinun on hyväksyttävä käyttöehdot jatkaaksesi."

#: accounts/templates/account/signup.html:47 accounts/templates/socialaccount/signup.html:46
msgid "Create account"
msgstr "Luo käyttäjätili"

#: accounts/templates/account/signup_closed.html:6
msgid "Sign up closed"
msgstr "Rekisteröityminen suljettu"

#: accounts/templates/account/signup_closed.html:9
msgid "We are sorry, but the sign up is currently closed."
msgstr "Rekisteröityminen on tällä hetkellä suljettu."

#: accounts/templates/account/signup_modal_terms_of_use.html:28 accounts/templates/account/terms_of_use.html:6 accounts/templates/account/terms_of_use_accept_form.html:6
msgid "Terms of use"
msgstr "Käyttöehdot"

#: accounts/templates/account/signup_modal_terms_of_use.html:43
msgid "I agree to the terms of use"
msgstr "Hyväksyn käyttöehdot"

#: accounts/templates/account/signup_modal_terms_of_use.html:46
msgid "Close"
msgstr "Sulje"

#: accounts/templates/account/terms_of_use_accept_form.html:24
msgid "I agree to the terms of use."
msgstr "Hyväksyn käyttöehdot."

#: accounts/templates/account/terms_of_use_accept_form.html:28
msgid "I accept"
msgstr "Hyväksyn"

#: accounts/templates/account/terms_of_use_accept_form.html:33
msgid "You have accepted the terms of use."
msgstr "Olet hyväksynyt käyttöehdot."

#: accounts/templates/account/verification_sent.html:7 accounts/templates/account/verified_email_required.html:6
msgid "Verify your e-mail address"
msgstr "Vahvista sähköpostiosoitteesi"

#: accounts/templates/account/verification_sent.html:11
msgid "We have sent an e-mail to you for verification. Follow the link provided to finalize the signup process. Please contact us if you do not receive it within a few minutes."
msgstr "Olemme lähettäneet sinulle vahvistusviestin. Viimeistele rekisteröityminen seuraamalla viestissä olevaa linkkiä. Ota yhteyttä, jos et saa viestiä muutaman minuutin kuluessa."

#: accounts/templates/account/verified_email_required.html:11
msgid "This part of the site requires us to verify that you are who you claim to be. For this purpose, we require that you verify ownership of your e-mail address."
msgstr "Tämä sivuston osa edellyttää, että voimme varmistaa henkilöllisyytesi. Tätä varten sinun on vahvistettava sähköpostiosoitteesi omistajuus."

#: accounts/templates/account/verified_email_required.html:15
msgid "We have sent an e-mail to you for verification. Please click on the link inside this e-mail. Please contact us if you do not receive it within a few minutes."
msgstr "Olemme lähettäneet sinulle vahvistusviestin. Napsauta viestissä olevaa linkkiä. Ota yhteyttä, jos et saa viestiä muutaman minuutin kuluessa."

#: accounts/templates/account/verified_email_required.html:19
#, python-format
msgid "<strong>Note:</strong> you can still <a href=\"%(email_url)s\">change your e-mail address</a>."
msgstr "<strong>Huomaa:</strong> voit edelleen <a href=\"%(email_url)s\">vaihtaa sähköpostiosoitteesi</a>."

#: accounts/templates/profile/profile_remove_closed.html:6 accounts/templates/profile/profile_remove_failed.html:6 accounts/templates/profile/profile_remove_form.html:7 accounts/templates/profile/profile_remove_form.html:17 accounts/templates/profile/profile_remove_success.html:6
#: accounts/templates/profile/profile_update_form.html:30 accounts/templates/profile/profile_update_form.html:37 core/templates/core/base_navigation.html:93
msgid "Delete profile"
msgstr "Poista profiili"

#: accounts/templates/profile/profile_remove_closed.html:9
msgid "We are sorry, but you cannot remove your profile here."
msgstr "Profiilia ei voi poistaa täällä."

#: accounts/templates/profile/profile_remove_failed.html:9
msgid "Profile removal failed. Please make sure that you enter the correct data."
msgstr "Profiilin poistaminen epäonnistui. Varmista, että annat oikeat tiedot."

#: accounts/templates/profile/profile_remove_form.html:9
msgid "If you are willing to remove all your account information please proceed by entering the necessary data below. Once completed this can not be undone."
msgstr "Jos haluat poistaa kaikki käyttäjätilisi tiedot, jatka antamalla tarvittavat tiedot alla. Kun poisto on tehty, sitä ei voi perua."

#: accounts/templates/profile/profile_remove_form.html:18 accounts/templates/profile/profile_update_form.html:25 core/templates/core/bootstrap_delete_form.html:8 core/templates/core/bootstrap_form.html:15 management/templates/management/upload.html:88 projects/templates/projects/project_import.html:164
msgid "Cancel"
msgstr "Peruuta"

#: accounts/templates/profile/profile_remove_success.html:9
msgid "Your profile was successfully removed."
msgstr "Profiilisi poistettiin onnistuneesti."

#: accounts/templates/profile/profile_update_closed.html:6
msgid "Profile update"
msgstr "Profiilin päivittäminen"

#: accounts/templates/profile/profile_update_closed.html:9
msgid "We are sorry, but you cannot update your profile here."
msgstr "Profiilia ei voi päivittää täällä."

#: accounts/templates/profile/profile_update_form.html:6 accounts/templates/profile/profile_update_form.html:24 core/templates/core/base_navigation.html:69
msgid "Update profile"
msgstr "Päivitä profiili"

#: accounts/templates/profile/profile_update_form.html:12
#, python-format
msgid "Please enter your updated account information. You can change your password using the <a href=\"%(password_url)s\">password form</a> and update your e-mail using the <a href=\"%(email_url)s\">e-mail form</a>."
msgstr "Päivitä käyttäjätilisi tiedot. Voit vaihtaa salasanasi <a href=\"%(password_url)s\">salasanalomakkeella</a> ja päivittää sähköpostiosoitteesi <a href=\"%(email_url)s\">sähköpostilomakkeella</a>."

#: accounts/templates/profile/profile_update_form.html:33
msgid "If you want to remove all your account information please proceed by clicking the button below."
msgstr "Jos haluat poistaa kaikki käyttäjätilisi tiedot, jatka napsauttamalla alla olevaa painiketta."

#: accounts/templates/socialaccount/authentication_error.html:9
msgid "Social Network Login Failure"
msgstr "Kirjautuminen ulkoisella tilillä epäonnistui"

#: accounts/templates/socialaccount/authentication_error.html:12
msgid "An error occurred while attempting to login via your social network account."
msgstr "Kirjautumisessa ulkoisen tilin kautta tapahtui virhe."

#: accounts/templates/socialaccount/connections.html:8 core/templates/core/base_navigation_socialaccount.html:4
msgid "Account connections"
msgstr "Tilin yhteydet"

#: accounts/templates/socialaccount/connections.html:10
msgid "Current connections"
msgstr "Nykyiset yhteydet"

#: accounts/templates/socialaccount/connections.html:15
msgid "You can sign in to your account using any of the following third party accounts:"
msgstr "Voit kirjautua käyttäjätilillesi käyttämällä mitä tahansa seuraavista kolmannen osapuolen tileistä:"

#: accounts/templates/socialaccount/connections.html:48
msgid "Remove selected account"
msgstr "Poista valittu tili"

#: accounts/templates/socialaccount/connections.html:62
msgid "You currently have no social network accounts connected to this account."
msgstr "Tähän käyttäjätiliin ei ole tällä hetkellä liitetty ulkoisia tilejä."

#: accounts/templates/socialaccount/connections.html:69
msgid "Add an additional account"
